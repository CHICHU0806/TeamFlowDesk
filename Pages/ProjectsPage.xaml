<Page
    x:Class="TeamFlowDesk.Pages.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#080D18" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#162033" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />

        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#FB7185" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="EditorBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1C2638" />
            <Setter Property="BorderBrush" Value="#40516B" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <DataTemplate x:Key="ProjectCardTemplate">
            <Border
                Margin="0,0,0,14"
                Padding="20"
                CornerRadius="20"
                Background="#1B2537"
                BorderBrush="#334155"
                BorderThickness="1">

                <StackPanel Spacing="14">

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="5">
                            <TextBlock
                                Text="{Binding Name}"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Text="{Binding Description}"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap"
                                MaxLines="3"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#172033"
                            VerticalAlignment="Top">
                            <TextBlock
                                Text="{Binding Status}"
                                FontSize="13"
                                Foreground="{StaticResource AccentBlueBrush}" />
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#241F3A"
                            VerticalAlignment="Top">
                            <TextBlock
                                Text="{Binding RiskLevel}"
                                FontSize="13"
                                Foreground="{StaticResource AccentPurpleBrush}" />
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="13" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="5">
                                <TextBlock Text="负责人" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding OwnerName}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="13" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="5">
                                <TextBlock Text="当前阶段" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding CurrentStage}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Padding="13" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="5">
                                <TextBlock Text="进度" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding ProgressPercent}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="13" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="5">
                                <TextBlock Text="开始日期" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding StartDate}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="13" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="5">
                                <TextBlock Text="结束日期" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding EndDate}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button
                            Content="推进 10%"
                            Tag="{Binding Id}"
                            Click="IncreaseProjectProgressButton_Click" />

                        <Button
                            Content="标记进行中"
                            Tag="{Binding Id}"
                            Click="SetProjectRunningButton_Click" />

                        <Button
                            Content="标记关注"
                            Tag="{Binding Id}"
                            Click="SetProjectAttentionButton_Click" />

                        <Button
                            Content="标记高风险"
                            Tag="{Binding Id}"
                            Click="SetProjectHighRiskButton_Click" />

                        <Button
                            Content="标记完成"
                            Tag="{Binding Id}"
                            Click="SetProjectCompletedButton_Click" />

                        <Button
                            Content="删除项目"
                            Tag="{Binding Id}"
                            Click="DeleteProjectButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">

            <StackPanel Margin="28" Spacing="22">

                <Border
                    Padding="30"
                    CornerRadius="26"
                    BorderBrush="#7C3AED"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B0764" Offset="0" />
                            <GradientStop Color="#1E1B4B" Offset="0.45" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="12">
                            <TextBlock
                                Text="Project Control Center"
                                FontSize="42"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="项目总控台"
                                FontSize="23"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="从项目目标、负责人、阶段进度和风险等级出发，建立团队负责人视角下的项目运行总表。"
                                FontSize="15"
                                Foreground="{StaticResource MutedTextBrush}"
                                TextWrapping="Wrap"
                                MaxWidth="820" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Padding="12,6" CornerRadius="999" Background="#312E81">
                                    <TextBlock Text="项目总览" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#1E3A8A">
                                    <TextBlock Text="阶段推进" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#064E3B">
                                    <TextBlock Text="负责人跟踪" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#7C2D12">
                                    <TextBlock Text="风险识别" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="20"
                            CornerRadius="20"
                            Background="#241B2D47"
                            BorderBrush="#475569"
                            BorderThickness="1">

                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="当前项目态势"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    x:Name="ProjectStatusSummaryText"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap" />

                                <Border Padding="12" CornerRadius="14" Background="#241F3A">
                                    <TextBlock
                                        Text="建议负责人优先检查高风险项目，再推进进行中项目，并及时更新阶段与进度。"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="项目总数" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="ProjectCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                            <TextBlock Text="纳入管理的项目" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="进行中" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="RunningProjectCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock Text="当前推进项目" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="风险项目" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="RiskProjectCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" />
                            <TextBlock Text="需要负责人关注" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="平均进度" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="AverageProgressText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock Text="项目整体推进度" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.35*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="新增项目"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="项目记录应明确目标、负责人、当前阶段、时间边界和风险状态。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBox
                                x:Name="ProjectNameTextBox"
                                Header="项目名称"
                                PlaceholderText="例如：TeamFlowDesk 团队管理系统"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="ProjectOwnerTextBox"
                                Header="负责人"
                                PlaceholderText="例如：杨杨文琦"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="ProjectStageTextBox"
                                Header="当前阶段"
                                PlaceholderText="例如：核心页面重构 / SQLite 接入 / 答辩准备"
                                Style="{StaticResource EditorBoxStyle}" />

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <DatePicker
                                    x:Name="ProjectStartDatePicker"
                                    Grid.Column="0"
                                    Header="开始日期" />

                                <DatePicker
                                    x:Name="ProjectEndDatePicker"
                                    Grid.Column="1"
                                    Header="结束日期" />
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox
                                    x:Name="ProjectStatusComboBox"
                                    Grid.Column="0"
                                    Header="项目状态"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="进行中" />
                                    <ComboBoxItem Content="关注" />
                                    <ComboBoxItem Content="滞后" />
                                    <ComboBoxItem Content="已完成" />
                                </ComboBox>

                                <ComboBox
                                    x:Name="ProjectRiskComboBox"
                                    Grid.Column="1"
                                    Header="风险等级"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="正常" />
                                    <ComboBoxItem Content="中风险" />
                                    <ComboBoxItem Content="高风险" />
                                </ComboBox>

                                <TextBox
                                    x:Name="ProjectProgressTextBox"
                                    Grid.Column="2"
                                    Header="进度百分比"
                                    PlaceholderText="例如：60"
                                    Style="{StaticResource EditorBoxStyle}" />
                            </Grid>

                            <TextBox
                                x:Name="ProjectDescriptionTextBox"
                                Header="项目说明"
                                PlaceholderText="描述项目目标、应用场景和当前重点"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="100"
                                MaxHeight="190"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                Style="{StaticResource EditorBoxStyle}" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button
                                    Content="新增项目"
                                    Click="AddProjectButton_Click" />

                                <Button
                                    Content="清空输入"
                                    Click="ClearProjectFormButton_Click" />
                            </StackPanel>

                            <TextBlock
                                x:Name="ProjectFormMessageText"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock
                                        Text="项目推进洞察"
                                        FontSize="25"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PrimaryTextBrush}" />

                                    <TextBlock
                                        Text="从项目进度、风险等级和负责人分布中判断团队整体推进是否健康。"
                                        FontSize="14"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#241F3A" VerticalAlignment="Center">
                                    <TextBlock Text="Live From SQLite" FontSize="13" Foreground="{StaticResource AccentPurpleBrush}" />
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="推进判断" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="ProjectProgressInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="风险判断" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="ProjectRiskInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="负责人分布" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="ProjectOwnerInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="项目管理闭环" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock
                                        Text="项目立项 → 任务拆解 → 人员分配 → 资源保障 → AI 协作 → 周报复盘 → 首页驾驶舱汇总"
                                        FontSize="15"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="24"
                    CornerRadius="24"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="项目运行总表"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="以项目卡片形式展示当前团队项目的阶段、进度、风险和负责人。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>

                            <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#241F3A" VerticalAlignment="Center">
                                <TextBlock Text="Project Ledger" FontSize="13" Foreground="{StaticResource AccentPurpleBrush}" />
                            </Border>
                        </Grid>

                        <ItemsControl
                            x:Name="ProjectsItemsControl"
                            ItemTemplate="{StaticResource ProjectCardTemplate}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>