<Page
    x:Class="TeamFlowDesk.Pages.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock
                    Text="项目管理"
                    FontSize="32"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="用于维护团队内部项目的基本信息、阶段计划、当前进度和风险状态。"
                    FontSize="16"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="项目总数" FontSize="14" />
                        <TextBlock x:Name="ProjectCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="进行中项目" FontSize="14" />
                        <TextBlock x:Name="ActiveProjectCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="风险项目" FontSize="14" />
                        <TextBlock x:Name="RiskProjectCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock
                    Text="项目列表"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <ListView
                    x:Name="ProjectsListView"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12"
                                Margin="0,0,0,8"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel Spacing="6">
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding Description}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{Binding OwnerName}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding CurrentStage}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{Binding RiskLevel}"
                                            FontSize="14" />
                                    </Grid>

                                    <ProgressBar
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{Binding ProgressPercent}" />

                                    <TextBlock
                                        Text="{Binding ProgressPercent}"
                                        FontSize="14" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>