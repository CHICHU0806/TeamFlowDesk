<Page
    x:Class="TeamFlowDesk.Pages.MembersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#080D18" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#162033" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />

        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#FB7185" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="EditorBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1C2638" />
            <Setter Property="BorderBrush" Value="#40516B" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <DataTemplate x:Key="MemberCardTemplate">
            <Border
                Margin="0,0,0,14"
                Padding="18"
                CornerRadius="20"
                Background="#1B2537"
                BorderBrush="#334155"
                BorderThickness="1">

                <StackPanel Spacing="12">

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock
                                Text="{Binding Name}"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Text="{Binding Direction}"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#172033"
                            VerticalAlignment="Top">
                            <TextBlock
                                Text="{Binding AbilityLevel}"
                                FontSize="13"
                                Foreground="{StaticResource AccentBlueBrush}" />
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#241F3A"
                            VerticalAlignment="Top">
                            <TextBlock
                                Text="{Binding WorkloadStatus}"
                                FontSize="13"
                                Foreground="{StaticResource AccentPurpleBrush}" />
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="12" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="4">
                                <TextBlock Text="年级 / 班级" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding Grade}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="12" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="4">
                                <TextBlock Text="成员角色" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding Role}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Padding="12" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="4">
                                <TextBlock Text="当前任务数" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding CurrentTaskCount}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="14" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="6">
                                <TextBlock Text="能力标签" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                                <TextBlock
                                    Text="{Binding SkillTags}"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap"
                                    MaxLines="4"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="14" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="6">
                                <TextBlock Text="培养计划" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                                <TextBlock
                                    Text="{Binding GrowthPlan}"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap"
                                    MaxLines="4"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button
                            Content="任务 +1"
                            Tag="{Binding Id}"
                            Click="IncreaseTaskCountButton_Click" />

                        <Button
                            Content="任务 -1"
                            Tag="{Binding Id}"
                            Click="DecreaseTaskCountButton_Click" />

                        <Button
                            Content="正常"
                            Tag="{Binding Id}"
                            Click="SetNormalWorkloadButton_Click" />

                        <Button
                            Content="关注"
                            Tag="{Binding Id}"
                            Click="SetAttentionWorkloadButton_Click" />

                        <Button
                            Content="过载"
                            Tag="{Binding Id}"
                            Click="SetOverloadWorkloadButton_Click" />

                        <Button
                            Content="空闲"
                            Tag="{Binding Id}"
                            Click="SetIdleWorkloadButton_Click" />

                        <Button
                            Content="删除"
                            Tag="{Binding Id}"
                            Click="DeleteMemberButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer
            x:Name="RootScrollViewer"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">

            <StackPanel Margin="28" Spacing="22">

                <Border
                    Padding="30"
                    CornerRadius="26"
                    BorderBrush="#059669"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#064E3B" Offset="0" />
                            <GradientStop Color="#14532D" Offset="0.45" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="12">
                            <TextBlock
                                Text="Member Dispatch Center"
                                FontSize="42"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="人员调度中心"
                                FontSize="23"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="从成员方向、能力标签、任务负载和培养计划出发，帮助负责人判断谁能承担任务、谁需要关注、谁适合培养为后续骨干。"
                                FontSize="15"
                                Foreground="{StaticResource MutedTextBrush}"
                                TextWrapping="Wrap"
                                MaxWidth="820" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Padding="12,6" CornerRadius="999" Background="#064E3B">
                                    <TextBlock Text="成员画像" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#1E3A8A">
                                    <TextBlock Text="能力矩阵" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#7C2D12">
                                    <TextBlock Text="负载预警" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#312E81">
                                    <TextBlock Text="培养计划" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="20"
                            CornerRadius="20"
                            Background="#241B2D47"
                            BorderBrush="#475569"
                            BorderThickness="1">

                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="当前人员态势"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    x:Name="MemberStatusSummaryText"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap" />

                                <Border Padding="12" CornerRadius="14" Background="#143326">
                                    <TextBlock
                                        Text="建议负责人优先关注过载成员，同时把可独立完成任务的成员纳入关键任务推进。"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="成员总数" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="MemberCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock Text="已建立画像的成员" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="正常负载" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="NormalWorkloadCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock Text="可稳定参与任务" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="独立成员" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="IndependentCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                            <TextBlock Text="可独立完成或带人" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="任务负载" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="TotalTaskLoadText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" />
                            <TextBlock Text="当前成员任务总量" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.35*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="新增成员画像"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="人员管理的重点不是登记姓名，而是沉淀方向、能力、负载和培养路径。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBox
                                x:Name="MemberNameTextBox"
                                Header="成员姓名"
                                PlaceholderText="例如：杨杨文琦"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="MemberGradeTextBox"
                                Header="年级 / 班级"
                                PlaceholderText="例如：人工智能 01 班"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="MemberDirectionTextBox"
                                Header="方向归属"
                                PlaceholderText="例如：电控方向 / 机械方向 / 视觉方向"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="MemberRoleTextBox"
                                Header="成员角色"
                                PlaceholderText="例如：负责人 / 组长 / 普通成员"
                                Style="{StaticResource EditorBoxStyle}" />

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox
                                    x:Name="MemberAbilityComboBox"
                                    Grid.Column="0"
                                    Header="能力等级"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="入门" />
                                    <ComboBoxItem Content="熟悉" />
                                    <ComboBoxItem Content="可独立完成" />
                                    <ComboBoxItem Content="可带人" />
                                </ComboBox>

                                <ComboBox
                                    x:Name="MemberWorkloadComboBox"
                                    Grid.Column="1"
                                    Header="负载状态"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="正常" />
                                    <ComboBoxItem Content="关注" />
                                    <ComboBoxItem Content="过载" />
                                    <ComboBoxItem Content="空闲" />
                                </ComboBox>

                                <TextBox
                                    x:Name="MemberTaskCountTextBox"
                                    Grid.Column="2"
                                    Header="任务数量"
                                    PlaceholderText="例如：2"
                                    Style="{StaticResource EditorBoxStyle}" />
                            </Grid>

                            <TextBox
                                x:Name="MemberSkillTagsTextBox"
                                Header="能力标签"
                                PlaceholderText="例如：C#、WinUI、STM32、CAN、PID、文档写作"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="90"
                                MaxHeight="170"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="MemberGrowthPlanTextBox"
                                Header="培养计划 / 成长记录"
                                PlaceholderText="例如：后续可承担底盘控制相关任务"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="90"
                                MaxHeight="170"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                Style="{StaticResource EditorBoxStyle}" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button
                                    Content="新增成员"
                                    Click="AddMemberButton_Click" />

                                <Button
                                    Content="清空输入"
                                    Click="ClearMemberFormButton_Click" />
                            </StackPanel>

                            <TextBlock
                                x:Name="MemberFormMessageText"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock
                                        Text="人员调度洞察"
                                        FontSize="25"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PrimaryTextBrush}" />

                                    <TextBlock
                                        Text="从负载状态、能力等级和培养阶段中判断当前人员结构是否健康。"
                                        FontSize="14"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#143326" VerticalAlignment="Center">
                                    <TextBlock Text="Live From SQLite" FontSize="13" Foreground="{StaticResource AccentGreenBrush}" />
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="负载判断" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="WorkloadInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="能力结构" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="AbilityInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="培养建议" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="TrainingInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="人员管理闭环" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock
                                        Text="成员画像 → 能力标签 → 任务负载 → 风险关注 → 培养计划 → 任务分配优化"
                                        FontSize="15"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="24"
                    CornerRadius="24"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="成员能力矩阵"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="按成员画像展示方向、角色、能力、任务负载和培养计划，作为负责人分配任务的依据。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>

                            <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#143326" VerticalAlignment="Center">
                                <TextBlock Text="Capability Matrix" FontSize="13" Foreground="{StaticResource AccentGreenBrush}" />
                            </Border>
                        </Grid>

                        <ItemsControl
                            x:Name="MembersItemsControl"
                            ItemTemplate="{StaticResource MemberCardTemplate}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>