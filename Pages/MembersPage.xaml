<Page
    x:Class="TeamFlowDesk.Pages.MembersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock
                    Text="人员管理"
                    FontSize="32"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="用于记录团队成员信息、方向归属、能力标签、任务负载和培养状态，辅助负责人进行人员调度。"
                    FontSize="16"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="成员总数" FontSize="14" />
                        <TextBlock x:Name="MemberCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="正常负载" FontSize="14" />
                        <TextBlock x:Name="NormalWorkloadCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="可独立完成" FontSize="14" />
                        <TextBlock x:Name="IndependentCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="3"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="任务负载总数" FontSize="14" />
                        <TextBlock x:Name="TotalTaskLoadText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock
                    Text="成员能力矩阵"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <ListView
                    x:Name="MembersListView"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12"
                                Margin="0,0,0,8"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel Spacing="6">
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontSize="18"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding Direction}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{Binding Grade}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Role}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{Binding AbilityLevel}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="3"
                                            Text="{Binding WorkloadStatus}"
                                            FontSize="14" />
                                    </Grid>

                                    <TextBlock
                                        Text="{Binding SkillTags}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding GrowthPlan}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>