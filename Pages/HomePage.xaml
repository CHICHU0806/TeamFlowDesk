<Page
    x:Class="TeamFlowDesk.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>

        <DataTemplate x:Key="PriorityItemTemplate">
            <Border Style="{StaticResource ListItemCardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding Title}"
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            TextWrapping="Wrap" />

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource SmallTagStyle}"
                            Background="{StaticResource PurpleTagBackgroundBrush}"
                            VerticalAlignment="Top">
                            <TextBlock
                                Text="{Binding Source}"
                                FontSize="12"
                                Foreground="{StaticResource AccentPurpleBrush}" />
                        </Border>
                    </Grid>

                    <TextBlock
                        Text="{Binding Description}"
                        Style="{StaticResource BodyTextStyle}"
                        MaxLines="3"
                        TextTrimming="CharacterEllipsis" />

                    <TextBlock
                        Text="{Binding Severity}"
                        FontSize="13"
                        Foreground="{StaticResource AccentOrangeBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ActivityItemTemplate">
            <Border
                Style="{StaticResource ListItemCardStyle}"
                Padding="15"
                CornerRadius="16"
                Margin="0,0,0,12">

                <StackPanel Spacing="6">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding Title}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            TextWrapping="Wrap" />

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource SmallTagStyle}"
                            Padding="9,4"
                            Background="{StaticResource BlueTagBackgroundBrush}">
                            <TextBlock
                                Text="{Binding Tag}"
                                FontSize="12"
                                Foreground="{StaticResource AccentBlueBrush}" />
                        </Border>
                    </Grid>

                    <TextBlock
                        Text="{Binding Description}"
                        Style="{StaticResource MutedBodyTextStyle}"
                        MaxLines="3"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ProjectMiniCardTemplate">
            <Border
                Style="{StaticResource ListItemCardStyle}"
                Padding="16"
                CornerRadius="18"
                Margin="0,0,0,12">

                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding Name}"
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            TextWrapping="Wrap" />

                        <Border
                            Grid.Column="1"
                            Style="{StaticResource SmallTagStyle}"
                            Padding="9,4"
                            Background="{StaticResource BlueTagBackgroundBrush}">
                            <TextBlock
                                Text="{Binding Status}"
                                FontSize="12"
                                Foreground="{StaticResource AccentBlueBrush}" />
                        </Border>

                        <Border
                            Grid.Column="2"
                            Style="{StaticResource SmallTagStyle}"
                            Padding="9,4"
                            Background="{StaticResource PurpleTagBackgroundBrush}">
                            <TextBlock
                                Text="{Binding RiskLevel}"
                                FontSize="12"
                                Foreground="{StaticResource AccentPurpleBrush}" />
                        </Border>
                    </Grid>

                    <TextBlock
                        Text="{Binding CurrentStage}"
                        Style="{StaticResource BodyTextStyle}" />

                    <TextBlock
                        Text="{Binding OwnerName}"
                        Style="{StaticResource MutedBodyTextStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>

    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">

            <StackPanel Margin="28" Spacing="22">

                <Border
                    Padding="32"
                    CornerRadius="28"
                    BorderBrush="#5B5FE9"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#172554" Offset="0" />
                            <GradientStop Color="#312E81" Offset="0.45" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ColumnSpacing="30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="14">
                            <TextBlock
                                Text="TeamFlowDesk"
                                Style="{StaticResource HeroTitleTextStyle}"
                                FontSize="46" />

                            <TextBlock
                                Text="团队运行管理驾驶舱"
                                Style="{StaticResource HeroSubtitleTextStyle}"
                                FontSize="25" />

                            <TextBlock
                                Text="从项目、任务、人员、器材、AI 协作和周报复盘中汇总团队运行态势，帮助负责人快速判断当前应该优先处理什么。"
                                Style="{StaticResource HeroDescriptionTextStyle}"
                                MaxWidth="860" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    Padding="12,6"
                                    CornerRadius="999"
                                    Background="#1E3A8A">
                                    <TextBlock
                                        Text="项目总控"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border
                                    Padding="12,6"
                                    CornerRadius="999"
                                    Background="{StaticResource GreenTagBackgroundBrush}">
                                    <TextBlock
                                        Text="人员调度"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border
                                    Padding="12,6"
                                    CornerRadius="999"
                                    Background="{StaticResource OrangeTagBackgroundBrush}">
                                    <TextBlock
                                        Text="资源保障"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border
                                    Padding="12,6"
                                    CornerRadius="999"
                                    Background="#312E81">
                                    <TextBlock
                                        Text="AI 协作复盘"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="22"
                            CornerRadius="22"
                            Background="#241B2D47"
                            BorderBrush="{StaticResource StrongBorderBrush}"
                            BorderThickness="1">

                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="当前团队态势"
                                    FontSize="19"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    x:Name="DashboardStatusText"
                                    Style="{StaticResource BodyTextStyle}" />

                                <Border
                                    Padding="12"
                                    CornerRadius="14"
                                    Background="{StaticResource PurpleTagBackgroundBrush}">
                                    <TextBlock
                                        x:Name="PrioritySuggestionText"
                                        Style="{StaticResource MutedBodyTextStyle}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="项目总数" Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock
                                x:Name="ProjectCountText"
                                Style="{StaticResource MetricNumberTextStyle}"
                                Foreground="{StaticResource AccentPurpleBrush}" />
                            <TextBlock
                                x:Name="RiskProjectCountText"
                                Style="{StaticResource MutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="任务总数" Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock
                                x:Name="TaskCountText"
                                Style="{StaticResource MetricNumberTextStyle}"
                                Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock
                                x:Name="RiskTaskCountText"
                                Style="{StaticResource MutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="成员总数" Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock
                                x:Name="MemberCountText"
                                Style="{StaticResource MetricNumberTextStyle}"
                                Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock
                                x:Name="AttentionMemberCountText"
                                Style="{StaticResource MutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="器材总数" Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock
                                x:Name="EquipmentCountText"
                                Style="{StaticResource MetricNumberTextStyle}"
                                Foreground="{StaticResource AccentOrangeBrush}" />
                            <TextBlock
                                x:Name="AbnormalEquipmentCountText"
                                Style="{StaticResource MutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource InsightCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="AI 协作记录" Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock
                                x:Name="AiRecordCountText"
                                Style="{StaticResource MetricNumberTextStyle}"
                                FontSize="30"
                                Foreground="{StaticResource AccentPurpleBrush}" />
                            <TextBlock
                                Text="沉淀 AI 建议、人工判断和最终决策"
                                Style="{StaticResource MutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource InsightCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="周报复盘记录" Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock
                                x:Name="ReportCountText"
                                Style="{StaticResource MetricNumberTextStyle}"
                                FontSize="30"
                                Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock
                                Text="沉淀阶段复盘、风险记录和下周计划"
                                Style="{StaticResource MutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource InsightCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="管理闭环完整度" Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock
                                x:Name="ClosureScoreText"
                                Style="{StaticResource MetricNumberTextStyle}"
                                FontSize="30"
                                Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock
                                x:Name="ClosureScoreDescriptionText"
                                Style="{StaticResource MutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock
                                        Text="负责人优先处理事项"
                                        Style="{StaticResource SectionTitleTextStyle}" />

                                    <TextBlock
                                        Text="按照项目风险、任务阻塞、成员负载和器材状态自动汇总。"
                                        Style="{StaticResource SectionDescriptionTextStyle}" />
                                </StackPanel>

                                <Border
                                    Grid.Column="1"
                                    Style="{StaticResource SmallTagStyle}"
                                    Background="{StaticResource PurpleTagBackgroundBrush}"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        Text="Priority Queue"
                                        FontSize="13"
                                        Foreground="{StaticResource AccentPurpleBrush}" />
                                </Border>
                            </Grid>

                            <ItemsControl
                                x:Name="PriorityItemsControl"
                                ItemTemplate="{StaticResource PriorityItemTemplate}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock
                                        Text="当前进行中项目"
                                        Style="{StaticResource SectionTitleTextStyle}" />

                                    <TextBlock
                                        Text="优先展示风险项目和正在推进的主项目。"
                                        Style="{StaticResource SectionDescriptionTextStyle}" />
                                </StackPanel>

                                <Border
                                    Grid.Column="1"
                                    Style="{StaticResource SmallTagStyle}"
                                    Background="{StaticResource BlueTagBackgroundBrush}"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        Text="Projects"
                                        FontSize="13"
                                        Foreground="{StaticResource AccentBlueBrush}" />
                                </Border>
                            </Grid>

                            <ItemsControl
                                x:Name="RunningProjectsItemsControl"
                                ItemTemplate="{StaticResource ProjectMiniCardTemplate}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock
                                Text="最近 AI 协作"
                                Style="{StaticResource SectionTitleTextStyle}"
                                FontSize="24" />

                            <ItemsControl
                                x:Name="RecentAiRecordsItemsControl"
                                ItemTemplate="{StaticResource ActivityItemTemplate}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock
                                Text="最近周报复盘"
                                Style="{StaticResource SectionTitleTextStyle}"
                                FontSize="24" />

                            <ItemsControl
                                x:Name="RecentReportsItemsControl"
                                ItemTemplate="{StaticResource ActivityItemTemplate}" />
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>