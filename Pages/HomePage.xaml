<Page
    x:Class="TeamFlowDesk.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock
                    Text="管理驾驶舱"
                    FontSize="32"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="面向团队负责人的内部私有化工作流管理平台，用于汇总项目进度、任务风险、成员负载、器材状态和 AI 协作过程。"
                    FontSize="16"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="项目总数" FontSize="14" />
                        <TextBlock x:Name="ProjectCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="任务总数" FontSize="14" />
                        <TextBlock x:Name="TaskCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="高风险任务" FontSize="14" />
                        <TextBlock x:Name="RiskTaskCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="3"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="AI 协作记录" FontSize="14" />
                        <TextBlock x:Name="AiRecordCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="12">
                    <TextBlock
                        Text="项目概览"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <ListView
                        x:Name="ProjectsListView"
                        SelectionMode="None"
                        MaxHeight="300">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8" Spacing="4">
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding CurrentStage}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding RiskLevel}"
                                        FontSize="14" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="12">
                    <TextBlock
                        Text="近期任务"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <ListView
                        x:Name="TasksListView"
                        SelectionMode="None"
                        MaxHeight="300">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8" Spacing="4">
                                    <TextBlock
                                        Text="{Binding Title}"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding OwnerName}"
                                        FontSize="14" />

                                    <TextBlock
                                        Text="{Binding Status}"
                                        FontSize="14" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="12">
                    <TextBlock
                        Text="成员负载"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <ListView
                        x:Name="MembersListView"
                        SelectionMode="None"
                        MaxHeight="260">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8" Spacing="4">
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontSize="16"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding Direction}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding WorkloadStatus}"
                                        FontSize="14" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="12">
                    <TextBlock
                        Text="器材状态"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <ListView
                        x:Name="EquipmentListView"
                        SelectionMode="None"
                        MaxHeight="260">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8" Spacing="4">
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontSize="16"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding Status}"
                                        FontSize="14" />

                                    <TextBlock
                                        Text="{Binding RelatedTask}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock
                    Text="AI 管理提醒"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <ListView
                    x:Name="AiRecordsListView"
                    SelectionMode="None"
                    MaxHeight="260">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="8" Spacing="4">
                                <TextBlock
                                    Text="{Binding RelatedModule}"
                                    FontSize="16"
                                    FontWeight="SemiBold" />

                                <TextBlock
                                    Text="{Binding Question}"
                                    FontSize="14"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Text="{Binding FinalDecision}"
                                    FontSize="14"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>