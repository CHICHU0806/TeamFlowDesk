<Page
    x:Class="TeamFlowDesk.Pages.EquipmentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock
                    Text="器材管理"
                    FontSize="32"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="用于记录团队器材的库存、借用、归还、损坏、维护和任务关联情况。"
                    FontSize="16"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="器材总数" FontSize="14" />
                        <TextBlock x:Name="EquipmentCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="可用器材" FontSize="14" />
                        <TextBlock x:Name="AvailableEquipmentCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="使用中" FontSize="14" />
                        <TextBlock x:Name="UsingEquipmentCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="3"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="异常器材" FontSize="14" />
                        <TextBlock x:Name="AbnormalEquipmentCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock
                    Text="器材台账"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <ListView
                    x:Name="EquipmentListView"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12"
                                Margin="0,0,0,8"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel Spacing="6">
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap" />

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{Binding Code}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Category}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{Binding Status}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="3"
                                            Text="{Binding Location}"
                                            FontSize="14" />
                                    </Grid>

                                    <TextBlock
                                        Text="{Binding CurrentHolder}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding RelatedTask}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding MaintenanceRecord}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>