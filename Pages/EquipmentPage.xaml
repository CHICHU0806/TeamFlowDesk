<Page
    x:Class="TeamFlowDesk.Pages.EquipmentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#080D18" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#162033" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />

        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#FB7185" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="EditorBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1C2638" />
            <Setter Property="BorderBrush" Value="#40516B" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <DataTemplate x:Key="EquipmentCardTemplate">
            <Border
                Margin="0,0,0,14"
                Padding="18"
                CornerRadius="20"
                Background="#1B2537"
                BorderBrush="#334155"
                BorderThickness="1">

                <StackPanel Spacing="12">

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock
                                Text="{Binding Name}"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Text="{Binding Code}"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#172033"
                            VerticalAlignment="Top">
                            <TextBlock
                                Text="{Binding Category}"
                                FontSize="13"
                                Foreground="{StaticResource AccentBlueBrush}" />
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#241F3A"
                            VerticalAlignment="Top">
                            <TextBlock
                                Text="{Binding Status}"
                                FontSize="13"
                                Foreground="{StaticResource AccentPurpleBrush}" />
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="12" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="4">
                                <TextBlock Text="存放位置" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding Location}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="12" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="4">
                                <TextBlock Text="当前持有人" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding CurrentHolder}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Padding="12" CornerRadius="14" Background="#162033">
                            <StackPanel Spacing="4">
                                <TextBlock Text="关联任务" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding RelatedTask}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Padding="14" CornerRadius="14" Background="#162033">
                        <StackPanel Spacing="6">
                            <TextBlock
                                Text="维护记录"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource AccentOrangeBrush}" />

                            <TextBlock
                                Text="{Binding MaintenanceRecord}"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap"
                                MaxLines="4"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button
                            Content="可用"
                            Tag="{Binding Id}"
                            Click="SetAvailableEquipmentButton_Click" />

                        <Button
                            Content="使用中"
                            Tag="{Binding Id}"
                            Click="SetUsingEquipmentButton_Click" />

                        <Button
                            Content="待检查"
                            Tag="{Binding Id}"
                            Click="SetCheckingEquipmentButton_Click" />

                        <Button
                            Content="维修中"
                            Tag="{Binding Id}"
                            Click="SetMaintenanceEquipmentButton_Click" />

                        <Button
                            Content="损坏"
                            Tag="{Binding Id}"
                            Click="SetBrokenEquipmentButton_Click" />

                        <Button
                            Content="删除"
                            Tag="{Binding Id}"
                            Click="DeleteEquipmentButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer
            x:Name="RootScrollViewer"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">

            <StackPanel Margin="28" Spacing="22">

                <Border
                    Padding="30"
                    CornerRadius="26"
                    BorderBrush="#D97706"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C2D12" Offset="0" />
                            <GradientStop Color="#78350F" Offset="0.45" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="12">
                            <TextBlock
                                Text="Resource Support Center"
                                FontSize="42"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="资源保障中心"
                                FontSize="23"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="围绕器材状态、存放位置、持有人、关联任务和维护记录建立资源台账，帮助负责人判断当前资源是否能支撑任务推进。"
                                FontSize="15"
                                Foreground="{StaticResource MutedTextBrush}"
                                TextWrapping="Wrap"
                                MaxWidth="840" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Padding="12,6" CornerRadius="999" Background="#7C2D12">
                                    <TextBlock Text="器材台账" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#1E3A8A">
                                    <TextBlock Text="状态追踪" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#064E3B">
                                    <TextBlock Text="资源保障" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#312E81">
                                    <TextBlock Text="维护复盘" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="20"
                            CornerRadius="20"
                            Background="#241B2D47"
                            BorderBrush="#475569"
                            BorderThickness="1">

                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="当前资源态势"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    x:Name="EquipmentStatusSummaryText"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap" />

                                <Border Padding="12" CornerRadius="14" Background="#2A1F16">
                                    <TextBlock
                                        Text="建议负责人优先检查待检查、维修中和损坏器材，避免任务推进时才发现资源不可用。"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="器材总数" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="EquipmentCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" />
                            <TextBlock Text="已纳入管理的资源" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="可用器材" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="AvailableEquipmentCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock Text="可直接投入任务" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="使用中" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="UsingEquipmentCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock Text="已有任务占用" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="异常器材" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="AbnormalEquipmentCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" />
                            <TextBlock Text="需要检查或维修" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.35*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="新增器材台账"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="器材管理的重点不是登记物品，而是明确它是否可用、在哪里、谁在用、支撑哪个任务。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBox
                                x:Name="EquipmentNameTextBox"
                                Header="器材名称"
                                PlaceholderText="例如：STM32F407 主控板"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="EquipmentCodeTextBox"
                                Header="器材编号"
                                PlaceholderText="例如：C-BOARD-001"
                                Style="{StaticResource EditorBoxStyle}" />

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    x:Name="EquipmentCategoryTextBox"
                                    Grid.Column="0"
                                    Header="器材分类"
                                    PlaceholderText="例如：电控 / 机械 / 工具 / 电脑"
                                    Style="{StaticResource EditorBoxStyle}" />

                                <ComboBox
                                    x:Name="EquipmentStatusComboBox"
                                    Grid.Column="1"
                                    Header="当前状态"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="可用" />
                                    <ComboBoxItem Content="使用中" />
                                    <ComboBoxItem Content="待检查" />
                                    <ComboBoxItem Content="维修中" />
                                    <ComboBoxItem Content="损坏" />
                                </ComboBox>
                            </Grid>

                            <TextBox
                                x:Name="EquipmentLocationTextBox"
                                Header="存放位置"
                                PlaceholderText="例如：工程培训中心 / 实验室柜子 A3"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="EquipmentHolderTextBox"
                                Header="当前持有人"
                                PlaceholderText="例如：杨杨文琦 / 暂无人持有"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="EquipmentRelatedTaskTextBox"
                                Header="关联任务"
                                PlaceholderText="例如：任务作战板 UI 改造 / 底盘控制调试"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="EquipmentMaintenanceRecordTextBox"
                                Header="维护记录"
                                PlaceholderText="例如：2026-07-04 检查正常；下次使用前确认接口是否松动"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="100"
                                MaxHeight="190"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                Style="{StaticResource EditorBoxStyle}" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button
                                    Content="新增器材"
                                    Click="AddEquipmentButton_Click" />

                                <Button
                                    Content="清空输入"
                                    Click="ClearEquipmentFormButton_Click" />
                            </StackPanel>

                            <TextBlock
                                x:Name="EquipmentFormMessageText"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock
                                        Text="资源保障洞察"
                                        FontSize="25"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PrimaryTextBrush}" />

                                    <TextBlock
                                        Text="从可用率、异常状态和占用情况判断当前资源是否能支撑任务推进。"
                                        FontSize="14"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#2A1F16" VerticalAlignment="Center">
                                    <TextBlock Text="Live From SQLite" FontSize="13" Foreground="{StaticResource AccentOrangeBrush}" />
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="风险判断" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="EquipmentRiskInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="占用情况" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="EquipmentUsageInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="维护建议" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="EquipmentMaintenanceInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="器材管理闭环" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock
                                        Text="器材入库 → 状态登记 → 任务关联 → 使用追踪 → 异常维护 → 复盘沉淀"
                                        FontSize="15"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="24"
                    CornerRadius="24"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="器材资源台账"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="按器材卡片展示编号、分类、状态、位置、持有人、关联任务和维护记录。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>

                            <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#2A1F16" VerticalAlignment="Center">
                                <TextBlock Text="Resource Ledger" FontSize="13" Foreground="{StaticResource AccentOrangeBrush}" />
                            </Border>
                        </Grid>

                        <ItemsControl
                            x:Name="EquipmentItemsControl"
                            ItemTemplate="{StaticResource EquipmentCardTemplate}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>