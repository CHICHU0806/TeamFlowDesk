<Page
    x:Class="TeamFlowDesk.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#080D18" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#162033" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />

        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#FB7185" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="BoardColumnStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="EditorBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1C2638" />
            <Setter Property="BorderBrush" Value="#40516B" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}" />
        </Style>
        <DataTemplate x:Key="TaskCardTemplate">
            <Border
                Margin="0,0,0,12"
                Padding="14"
                CornerRadius="16"
                Background="#1B2537"
                BorderBrush="#334155"
                BorderThickness="1">

                <StackPanel Spacing="10">
                    <TextBlock
                        Text="{Binding Title}"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Text="{Binding Description}"
                        FontSize="13"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        TextWrapping="Wrap"
                        MaxLines="3"
                        TextTrimming="CharacterEllipsis" />

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="8,4" CornerRadius="999" Background="#172033">
                            <TextBlock
                                Text="{Binding OwnerName}"
                                FontSize="12"
                                Foreground="{StaticResource AccentBlueBrush}"
                                TextWrapping="Wrap" />
                        </Border>

                        <Border Grid.Column="1" Padding="8,4" CornerRadius="999" Background="#241F3A">
                            <TextBlock
                                Text="{Binding Priority}"
                                FontSize="12"
                                Foreground="{StaticResource AccentPurpleBrush}"
                                TextWrapping="Wrap" />
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding Status}"
                            FontSize="13"
                            Foreground="{StaticResource SecondaryTextBrush}" />

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding RiskLevel}"
                            FontSize="13"
                            Foreground="{StaticResource AccentRedBrush}" />
                    </Grid>

                    <TextBlock
                        Text="{Binding OutputRequirement}"
                        FontSize="13"
                        Foreground="{StaticResource MutedTextBrush}"
                        TextWrapping="Wrap"
                        MaxLines="2"
                        TextTrimming="CharacterEllipsis" />

                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Content="进行中"
                                Tag="{Binding Id}"
                                Click="SetDoingTaskButton_Click" />

                            <Button
                                Content="完成"
                                Tag="{Binding Id}"
                                Click="CompleteTaskButton_Click" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Content="高风险"
                                Tag="{Binding Id}"
                                Click="SetHighRiskTaskButton_Click" />

                            <Button
                                Content="删除"
                                Tag="{Binding Id}"
                                Click="DeleteTaskButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer
            x:Name="RootScrollViewer"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">

            <StackPanel Margin="28" Spacing="22">

                <Border
                    Padding="30"
                    CornerRadius="26"
                    BorderBrush="#2563EB"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#172554" Offset="0" />
                            <GradientStop Color="#1E1B4B" Offset="0.45" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="12">
                            <TextBlock
                                Text="Mission Board"
                                FontSize="42"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="任务作战板"
                                FontSize="23"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="围绕项目目标拆解任务、识别风险、跟踪负责人和输出要求，帮助负责人快速判断当前团队推进状态。"
                                FontSize="15"
                                Foreground="{StaticResource MutedTextBrush}"
                                TextWrapping="Wrap"
                                MaxWidth="820" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Padding="12,6" CornerRadius="999" Background="#1E3A8A">
                                    <TextBlock Text="任务拆解" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#064E3B">
                                    <TextBlock Text="状态追踪" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#7C2D12">
                                    <TextBlock Text="风险识别" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#312E81">
                                    <TextBlock Text="复盘沉淀" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="20"
                            CornerRadius="20"
                            Background="#241B2D47"
                            BorderBrush="#475569"
                            BorderThickness="1">

                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="当前任务态势"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    x:Name="TaskStatusSummaryText"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap" />

                                <Border Padding="12" CornerRadius="14" Background="#172033">
                                    <TextBlock
                                        Text="建议负责人优先处理风险任务，再推进进行中任务，最后补齐待处理任务的负责人和输出要求。"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="任务总数" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="TaskCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock Text="已纳入管理的任务" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="已完成" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="CompletedTaskCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock Text="已经完成闭环" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="进行中" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="DoingTaskCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                            <TextBlock Text="当前正在推进" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="风险任务" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="RiskTaskCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" />
                            <TextBlock Text="需要负责人关注" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="新增任务"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="任务不只是标题，还应该包含负责人、输出要求、关联器材和风险状态。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBox
                                x:Name="TaskTitleTextBox"
                                Header="任务名称"
                                PlaceholderText="例如：完成任务作战板 UI 改造"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="TaskOwnerTextBox"
                                Header="负责人"
                                PlaceholderText="例如：杨杨文琦"
                                Style="{StaticResource EditorBoxStyle}" />

                            <DatePicker
                                x:Name="TaskDeadlineDatePicker"
                                Header="截止日期" />

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox
                                    x:Name="TaskStatusComboBox"
                                    Grid.Column="0"
                                    Header="任务状态"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="待处理" />
                                    <ComboBoxItem Content="进行中" />
                                    <ComboBoxItem Content="已完成" />
                                    <ComboBoxItem Content="延期" />
                                    <ComboBoxItem Content="滞后" />
                                </ComboBox>

                                <ComboBox
                                    x:Name="TaskPriorityComboBox"
                                    Grid.Column="1"
                                    Header="优先级"
                                    SelectedIndex="1">
                                    <ComboBoxItem Content="低" />
                                    <ComboBoxItem Content="普通" />
                                    <ComboBoxItem Content="高" />
                                    <ComboBoxItem Content="紧急" />
                                </ComboBox>

                                <ComboBox
                                    x:Name="TaskRiskComboBox"
                                    Grid.Column="2"
                                    Header="风险等级"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="正常" />
                                    <ComboBoxItem Content="中风险" />
                                    <ComboBoxItem Content="高风险" />
                                </ComboBox>
                            </Grid>

                            <TextBox
                                x:Name="TaskDescriptionTextBox"
                                Header="任务描述"
                                PlaceholderText="描述这个任务要解决什么问题"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="90"
                                MaxHeight="180"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="TaskEquipmentTextBox"
                                Header="关联器材"
                                PlaceholderText="例如：F407 主控板 / 开发电脑 / 电机"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="TaskOutputTextBox"
                                Header="输出要求"
                                PlaceholderText="例如：完成可运行代码、截图、文档说明"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="80"
                                MaxHeight="150"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                Style="{StaticResource EditorBoxStyle}" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button
                                    Content="新增任务"
                                    Click="AddTaskButton_Click" />

                                <Button
                                    Content="清空输入"
                                    Click="ClearTaskFormButton_Click" />
                            </StackPanel>

                            <TextBlock
                                x:Name="TaskFormMessageText"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock
                                        Text="任务推进洞察"
                                        FontSize="25"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PrimaryTextBrush}" />

                                    <TextBlock
                                        Text="从任务状态、风险等级和负责人分布中判断当前推进是否健康。"
                                        FontSize="14"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#172033" VerticalAlignment="Center">
                                    <TextBlock Text="Live From SQLite" FontSize="13" Foreground="{StaticResource AccentBlueBrush}" />
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="优先处理建议" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="TaskPriorityInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="负责人负载提示" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="TaskOwnerInsightText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Padding="16" CornerRadius="18" Background="#1B2638" BorderBrush="#2F3D55" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="任务管理闭环" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock
                                        Text="任务拆解 → 负责人确认 → 输出要求明确 → 状态更新 → 风险复盘 → 首页驾驶舱汇总"
                                        FontSize="15"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="24"
                    CornerRadius="24"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="任务作战板"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="展示型看板跟随整个页面滚动，不使用内部固定滚动框。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>

                            <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#172033" VerticalAlignment="Center">
                                <TextBlock Text="Board View" FontSize="13" Foreground="{StaticResource AccentPurpleBrush}" />
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource BoardColumnStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="待处理" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                                    <ItemsControl x:Name="TodoTasksItemsControl" ItemTemplate="{StaticResource TaskCardTemplate}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource BoardColumnStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="进行中" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                                    <ItemsControl x:Name="DoingTasksItemsControl" ItemTemplate="{StaticResource TaskCardTemplate}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource BoardColumnStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="已完成" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                                    <ItemsControl x:Name="DoneTasksItemsControl" ItemTemplate="{StaticResource TaskCardTemplate}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Style="{StaticResource BoardColumnStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="风险任务" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" />
                                    <ItemsControl x:Name="RiskTasksItemsControl" ItemTemplate="{StaticResource TaskCardTemplate}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>