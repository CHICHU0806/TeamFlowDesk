<Page
    x:Class="TeamFlowDesk.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">

            <StackPanel Margin="28" Spacing="22">

                <Border
                    Padding="32"
                    CornerRadius="28"
                    BorderBrush="#5B5FE9"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#172554" Offset="0" />
                            <GradientStop Color="#312E81" Offset="0.45" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <StackPanel Spacing="10">
                        <TextBlock Text="系统设置" Style="{StaticResource HeroTitleTextStyle}" />
                        <TextBlock
                            Text="管理 AI 接口和本地数据备份。所有业务数据默认保存在当前 Windows 用户目录。"
                            Style="{StaticResource HeroDescriptionTextStyle}"
                            MaxWidth="900" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="AI 接口配置" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock
                                    Text="填写 OpenAI-compatible API 配置。API Key 只保存在本机用户目录，不会写入项目代码。"
                                    Style="{StaticResource SectionDescriptionTextStyle}" />
                            </StackPanel>

                            <TextBox
                                x:Name="AiBaseUrlTextBox"
                                Header="API Base URL"
                                PlaceholderText="例如：https://api.openai.com/v1"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="AiModelTextBox"
                                Header="模型名称"
                                PlaceholderText="填写当前 API 可用的模型名"
                                Style="{StaticResource EditorBoxStyle}" />

                            <PasswordBox
                                x:Name="AiApiKeyPasswordBox"
                                Header="API Key"
                                PlaceholderText="请输入 API Key" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button
                                    Content="保存 AI 配置"
                                    Click="SaveAiSettingsButton_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" />

                                <Button
                                    Content="重新读取"
                                    Click="ReloadAiSettingsButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}" />

                                <Button
                                    Content="清空配置"
                                    Click="ClearAiSettingsButton_Click"
                                    Style="{StaticResource DangerButtonStyle}" />
                            </StackPanel>

                            <TextBlock
                                x:Name="AiSettingsMessageText"
                                Style="{StaticResource MutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="20">
                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="本地数据与备份" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock
                                    Text="项目、任务、成员、器材、AI 协作记录和周报复盘使用 SQLite 本地持久化。备份会生成带时间戳的数据库副本。"
                                    Style="{StaticResource BodyTextStyle}" />
                                <Button
                                    Content="备份本地数据"
                                    Click="BackupDatabaseButton_Click"
                                    Style="{StaticResource SuccessButtonStyle}" />
                                <TextBlock
                                    x:Name="DataBackupMessageText"
                                    Style="{StaticResource MutedBodyTextStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="当前运行策略" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="本地私有化存储" Style="{StaticResource BodyTextStyle}" />
                                <TextBlock Text="周报复盘支持生成 TXT 阶段材料" Style="{StaticResource BodyTextStyle}" />
                                <TextBlock Text="AI 只提供建议，最终决策由负责人确认" Style="{StaticResource BodyTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
