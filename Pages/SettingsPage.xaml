<Page
    x:Class="TeamFlowDesk.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="20">

            <StackPanel Spacing="8">
                <TextBlock
                    Text="系统设置"
                    FontSize="32"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="用于配置系统运行方式、数据存储方式和后续扩展选项。当前阶段保留基础设置页面。"
                    FontSize="16"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock
                    Text="基础设置"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <CheckBox
                    Content="启动后默认进入管理驾驶舱"
                    IsChecked="True" />

                <CheckBox
                    Content="启用本地私有化数据存储提示"
                    IsChecked="True" />

                <CheckBox
                    Content="在周报中保留 AI 协作记录"
                    IsChecked="True" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock
                    Text="数据策略"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="当前版本以本地单机使用为主，后续可扩展 SQLite 数据持久化、数据备份、导出报告和局域网同步功能。"
                    FontSize="16"
                    TextWrapping="Wrap" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>