<Page
    x:Class="TeamFlowDesk.Pages.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock
                    Text="周报与复盘"
                    FontSize="32"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="用于沉淀每周项目进展、问题记录、下周计划、负责人评价和 AI 协作过程。"
                    FontSize="16"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="周报总数" FontSize="14" />
                        <TextBlock x:Name="ReportCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="正常进度" FontSize="14" />
                        <TextBlock x:Name="NormalProgressCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="AI 协作周报" FontSize="14" />
                        <TextBlock x:Name="AiReportCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock
                    Text="周报列表"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <ListView
                    x:Name="ReportsListView"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12"
                                Margin="0,0,0,8"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel Spacing="8">

                                    <TextBlock
                                        Text="{Binding Title}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap" />

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{Binding StartDate}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding EndDate}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{Binding ProgressStatus}"
                                            FontSize="14" />
                                    </Grid>

                                    <TextBlock
                                        Text="本周完成"
                                        FontSize="14"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding CompletedWork}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="存在问题"
                                        FontSize="14"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding Problems}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="下周计划"
                                        FontSize="14"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding NextPlan}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="AI 协作总结"
                                        FontSize="14"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding AiCollaborationSummary}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="负责人复盘"
                                        FontSize="14"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding ManagerReview}"
                                        FontSize="14"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>