<Page
    x:Class="TeamFlowDesk.Pages.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#090E1A" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#172033" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#FB7185" />
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer>
            <StackPanel Margin="32" Spacing="24">

                <Border
                    Padding="28"
                    CornerRadius="24"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#312E81" Offset="0" />
                            <GradientStop Color="#1E3A8A" Offset="0.45" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="12">
                            <TextBlock
                                Text="复盘中心"
                                FontSize="40"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="周报、问题、AI 协作与负责人判断的统一沉淀区"
                                FontSize="21"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="将任务推进、人员负载、器材状态和 AI 协作过程汇总为可追踪、可复盘、可继续优化的团队运行记录。"
                                FontSize="15"
                                Foreground="{StaticResource MutedTextBrush}"
                                TextWrapping="Wrap"
                                MaxWidth="760" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="22"
                            CornerRadius="20"
                            Background="#201E293B"
                            BorderBrush="#475569"
                            BorderThickness="1">

                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="复盘状态"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    x:Name="ReviewStatusText"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Text="建议每周至少形成一条复盘记录，并保留 AI 协作摘要与人工判断。"
                                    FontSize="13"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="20" CornerRadius="20" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="周报总数" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="ReportCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock Text="已沉淀的复盘记录" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="20" CornerRadius="20" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="正常进度" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="NormalProgressCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock Text="推进状态良好的记录" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="20" CornerRadius="20" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="风险复盘" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="RiskReportCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" />
                            <TextBlock Text="需要重点关注的复盘" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Padding="20" CornerRadius="20" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="AI 协作周报" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="AiReportCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                            <TextBlock Text="包含 AI 摘要的记录" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="22"
                    CornerRadius="22"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="18">

                        <StackPanel Spacing="4">
                            <TextBlock
                                Text="新增复盘记录"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="可以手动填写，也可以先根据当前任务、AI 记录、人员和器材状态生成一份复盘草稿。"
                                FontSize="14"
                                Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>

                        <Grid ColumnSpacing="16" RowSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                x:Name="ReportTitleTextBox"
                                Grid.Row="0"
                                Grid.Column="0"
                                Header="周报标题"
                                PlaceholderText="例如：TeamFlowDesk 第二周项目复盘" />

                            <DatePicker
                                x:Name="ReportStartDatePicker"
                                Grid.Row="0"
                                Grid.Column="1"
                                Header="开始日期" />

                            <DatePicker
                                x:Name="ReportEndDatePicker"
                                Grid.Row="0"
                                Grid.Column="2"
                                Header="结束日期" />

                            <ComboBox
                                x:Name="ProgressStatusComboBox"
                                Grid.Row="1"
                                Grid.Column="0"
                                Header="进度状态"
                                SelectedIndex="0">
                                <ComboBoxItem Content="正常" />
                                <ComboBoxItem Content="关注" />
                                <ComboBoxItem Content="滞后" />
                                <ComboBoxItem Content="高风险" />
                                <ComboBoxItem Content="已完成" />
                            </ComboBox>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Bottom">

                                <Button
                                    Content="根据当前数据生成复盘草稿"
                                    Click="GenerateReportDraftButton_Click" />

                                <Button
                                    Content="保存复盘"
                                    Click="AddReportButton_Click" />

                                <Button
                                    Content="清空输入"
                                    Click="ClearReportFormButton_Click" />
                            </StackPanel>

                            <TextBox
                                x:Name="CompletedWorkTextBox"
                                Grid.Row="2"
                                Grid.Column="0"
                                Header="本周完成工作"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="120" />

                            <TextBox
                                x:Name="ProblemsTextBox"
                                Grid.Row="2"
                                Grid.Column="1"
                                Header="问题与风险"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="120" />

                            <TextBox
                                x:Name="NextPlanTextBox"
                                Grid.Row="2"
                                Grid.Column="2"
                                Header="下周计划"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="120" />

                            <TextBox
                                x:Name="AiCollaborationSummaryTextBox"
                                Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Header="AI 协作摘要"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="110" />

                            <TextBox
                                x:Name="ManagerReviewTextBox"
                                Grid.Row="3"
                                Grid.Column="2"
                                Header="负责人复盘判断"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="110" />

                            <TextBlock
                                x:Name="ReportFormMessageText"
                                Grid.Row="4"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Padding="22"
                    CornerRadius="22"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock
                                Text="复盘时间线"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="按时间沉淀团队管理过程，形成后续答辩、交接和优化的依据。"
                                FontSize="14"
                                Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>

                        <ListView
                            x:Name="ReportsListView"
                            SelectionMode="Single"
                            Background="Transparent">

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="18"
                                        CornerRadius="18"
                                        Background="#1F2937"
                                        BorderBrush="#334155"
                                        BorderThickness="1">

                                        <StackPanel Spacing="10">
                                            <Grid ColumnSpacing="16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Column="0"
                                                    Text="{Binding Title}"
                                                    FontSize="20"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource PrimaryTextBrush}"
                                                    TextWrapping="Wrap" />

                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{Binding ProgressStatus}"
                                                    FontSize="14"
                                                    Foreground="{StaticResource AccentOrangeBrush}" />

                                                <TextBlock
                                                    Grid.Column="2"
                                                    Text="{Binding EndDate}"
                                                    FontSize="13"
                                                    Foreground="{StaticResource MutedTextBrush}" />
                                            </Grid>

                                            <TextBlock Text="本周完成工作" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                                            <TextBlock Text="{Binding CompletedWork}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />

                                            <TextBlock Text="问题与风险" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" />
                                            <TextBlock Text="{Binding Problems}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />

                                            <TextBlock Text="下周计划" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                                            <TextBlock Text="{Binding NextPlan}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />

                                            <TextBlock Text="AI 协作摘要" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                                            <TextBlock Text="{Binding AiCollaborationSummary}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />

                                            <TextBlock Text="负责人复盘判断" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" />
                                            <TextBlock Text="{Binding ManagerReview}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />

                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <Button
                                                    Content="标记正常"
                                                    Tag="{Binding Id}"
                                                    Click="SetNormalReportButton_Click" />

                                                <Button
                                                    Content="标记关注"
                                                    Tag="{Binding Id}"
                                                    Click="SetAttentionReportButton_Click" />

                                                <Button
                                                    Content="标记高风险"
                                                    Tag="{Binding Id}"
                                                    Click="SetHighRiskReportButton_Click" />

                                                <Button
                                                    Content="删除复盘"
                                                    Tag="{Binding Id}"
                                                    Click="DeleteReportButton_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>