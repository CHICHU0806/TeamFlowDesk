<Page
    x:Class="TeamFlowDesk.Pages.AiRecordsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#080D18" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#121A2B" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#172033" />
        <SolidColorBrush x:Key="CardSoftBrush" Color="#1D2840" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />

        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#FB7185" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="EditorBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#202A3F" />
            <Setter Property="BorderBrush" Value="#3B4A63" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer>
            <StackPanel Margin="32" Spacing="24">

                <Border
                    Padding="30"
                    CornerRadius="28"
                    BorderBrush="#7C3AED"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B0764" Offset="0" />
                            <GradientStop Color="#312E81" Offset="0.48" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="14">
                            <TextBlock
                                Text="AI Command Console"
                                FontSize="44"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="AI 协作调度台"
                                FontSize="24"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="记录 AI 在任务拆解、风险分析、复盘生成和管理决策中的辅助过程，并保留人工判断、修正意见和最终采纳结果。"
                                FontSize="15"
                                Foreground="{StaticResource MutedTextBrush}"
                                TextWrapping="Wrap"
                                MaxWidth="820" />

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Padding="12,6" CornerRadius="999" Background="#312E81">
                                    <TextBlock Text="用户自定义 API" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#4C1D95">
                                    <TextBlock Text="AI 建议生成" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#064E3B">
                                    <TextBlock Text="人工判断闭环" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#7C2D12">
                                    <TextBlock Text="采纳状态追踪" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="22"
                            CornerRadius="22"
                            Background="#251E293B"
                            BorderBrush="#475569"
                            BorderThickness="1">

                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="AI 调度状态"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    x:Name="AiConfigStatusText"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap" />

                                <Border Padding="12" CornerRadius="14" Background="#241F3A">
                                    <TextBlock
                                        Text="AI 只提供建议，最终判断、取舍和管理动作仍由负责人完成。"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="记录总数" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="RecordCountText" FontSize="38" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock Text="已沉淀的 AI 协作过程" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="采纳记录" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="AcceptedCountText" FontSize="38" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock Text="AI 建议被直接采纳" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="部分采纳" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="PartAcceptedCountText" FontSize="38" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                            <TextBlock Text="经人工修正后使用" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="涉及模块" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="ModuleCountText" FontSize="38" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" />
                            <TextBlock Text="AI 参与的管理场景" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="24"
                        CornerRadius="26"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="AI 输入区"
                                    FontSize="26"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="先描述问题，再调用用户配置的 API 生成管理建议。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBox
                                x:Name="RelatedModuleTextBox"
                                Header="关联模块"
                                PlaceholderText="例如：任务管理 / 周报复盘 / 人员调度 / 器材风险"
                                Style="{StaticResource EditorBoxStyle}" />

                            <ComboBox
                                x:Name="AdoptionStatusComboBox"
                                Header="采纳状态"
                                SelectedIndex="1">
                                <ComboBoxItem Content="采纳" />
                                <ComboBoxItem Content="部分采纳" />
                                <ComboBoxItem Content="未采纳" />
                                <ComboBoxItem Content="待判断" />
                            </ComboBox>

                            <TextBox
                                x:Name="QuestionTextBox"
                                Header="问题描述"
                                PlaceholderText="例如：当前任务较多，如何判断哪些任务需要优先处理？"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="170"
                                Style="{StaticResource EditorBoxStyle}" />

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button
                                    x:Name="GenerateAiSuggestionButton"
                                    Content="生成 AI 建议"
                                    Click="GenerateAiSuggestionButton_Click" />

                                <Button
                                    Content="保存记录"
                                    Click="AddAiRecordButton_Click" />

                                <Button
                                    Content="清空"
                                    Click="ClearAiRecordFormButton_Click" />
                            </StackPanel>

                            <TextBlock
                                x:Name="AiRecordFormMessageText"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="24"
                        CornerRadius="26"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="建议与判断"
                                    FontSize="26"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="AI 建议只作为参考，必须经过人工判断后才能形成最终决策。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBox
                                x:Name="AiSuggestionTextBox"
                                Header="AI 建议"
                                PlaceholderText="点击左侧“生成 AI 建议”后，这里会自动填入内容。"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="170"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="HumanJudgementTextBox"
                                Header="人工判断"
                                PlaceholderText="记录你对 AI 建议的判断、筛选、质疑、补充或修正。"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="135"
                                Style="{StaticResource EditorBoxStyle}" />

                            <TextBox
                                x:Name="FinalDecisionTextBox"
                                Header="最终决策"
                                PlaceholderText="记录最终采用的方案，以及为什么这样处理。"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="135"
                                Style="{StaticResource EditorBoxStyle}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2" Spacing="18">

                        <Border
                            Padding="22"
                            CornerRadius="24"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1">

                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Text="协作洞察"
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PrimaryTextBrush}" />

                                    <TextBlock
                                        Text="帮助负责人判断 AI 是否真正进入管理流程。"
                                        FontSize="14"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Padding="14" CornerRadius="16" Background="#241F3A">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="最近协作模块" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="RecentModuleText" FontSize="15" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Padding="14" CornerRadius="16" Background="#1F2937">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="采纳结构" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="AdoptionSummaryText" FontSize="15" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Padding="14" CornerRadius="16" Background="#1F2937">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="管理价值" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock x:Name="AiValueText" FontSize="15" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="22"
                            CornerRadius="24"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1">

                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="AI 协作闭环"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock Text="1. 负责人提出管理问题" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="2. AI 给出结构化建议" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="3. 负责人进行人工判断" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="4. 形成最终管理动作" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="5. 保存为可复盘记录" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border
                    Padding="24"
                    CornerRadius="26"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="AI 协作时间线"
                                    FontSize="26"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="每一条记录都应该能回答：AI 提了什么、人怎么判断、最后采取了什么方案。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>

                            <TextBlock
                                Grid.Column="1"
                                Text="Decision Trace"
                                FontSize="18"
                                Foreground="{StaticResource AccentPurpleBrush}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <ListView
                            x:Name="AiRecordsListView"
                            SelectionMode="Single"
                            Background="Transparent"
                            Height="680">

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,14"
                                        Padding="20"
                                        CornerRadius="22"
                                        Background="#1F2937"
                                        BorderBrush="#334155"
                                        BorderThickness="1">

                                        <Grid ColumnSpacing="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <Border Width="16" Height="16" CornerRadius="8" Background="#A78BFA" />
                                                <Rectangle Width="2" Height="300" Fill="#334155" Margin="0,8,0,0" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="10">

                                                <Grid ColumnSpacing="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock
                                                        Grid.Column="0"
                                                        Text="{Binding RelatedModule}"
                                                        FontSize="21"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource PrimaryTextBrush}"
                                                        TextWrapping="Wrap" />

                                                    <Border
                                                        Grid.Column="1"
                                                        Padding="10,4"
                                                        CornerRadius="999"
                                                        Background="#334155">
                                                        <TextBlock
                                                            Text="{Binding AdoptionStatus}"
                                                            FontSize="13"
                                                            Foreground="{StaticResource AccentPurpleBrush}" />
                                                    </Border>

                                                    <TextBlock
                                                        Grid.Column="2"
                                                        Text="{Binding CreatedAt}"
                                                        FontSize="13"
                                                        Foreground="{StaticResource MutedTextBrush}"
                                                        VerticalAlignment="Center" />
                                                </Grid>

                                                <Border Padding="14" CornerRadius="14" Background="#172033">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="问题描述" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                                                        <TextBlock Text="{Binding Question}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>

                                                <Grid ColumnSpacing="14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Spacing="8">
                                                        <TextBlock Text="AI 建议" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                                                        <TextBlock Text="{Binding AiSuggestion}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" MaxHeight="120" />

                                                        <TextBlock Text="人工判断" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" />
                                                        <TextBlock Text="{Binding HumanJudgement}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" MaxHeight="100" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Spacing="8">
                                                        <TextBlock Text="最终决策" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                                                        <TextBlock Text="{Binding FinalDecision}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" MaxHeight="160" />
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Button
                                                        Content="标记采纳"
                                                        Tag="{Binding Id}"
                                                        Click="SetAcceptedButton_Click" />

                                                    <Button
                                                        Content="标记部分采纳"
                                                        Tag="{Binding Id}"
                                                        Click="SetPartAcceptedButton_Click" />

                                                    <Button
                                                        Content="标记未采纳"
                                                        Tag="{Binding Id}"
                                                        Click="SetRejectedButton_Click" />

                                                    <Button
                                                        Content="删除记录"
                                                        Tag="{Binding Id}"
                                                        Click="DeleteAiRecordButton_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>