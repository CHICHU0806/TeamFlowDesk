<Page
    x:Class="TeamFlowDesk.Pages.AiRecordsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#080D18" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#162033" />
        <SolidColorBrush x:Key="CardSoftBrush" Color="#1E293B" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />

        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />

        <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#FB7185" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InsightCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="#1B2638" />
            <Setter Property="BorderBrush" Value="#2F3D55" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="EditorBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1C2638" />
            <Setter Property="BorderBrush" Value="#40516B" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">

            <StackPanel Margin="28" Spacing="22">

                <Border
                    Padding="30"
                    CornerRadius="26"
                    BorderBrush="#5B5FE9"
                    BorderThickness="1">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2E1065" Offset="0" />
                            <GradientStop Color="#1E1B4B" Offset="0.45" />
                            <GradientStop Color="#0F172A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="12">
                            <TextBlock
                                Text="AI Command Console"
                                FontSize="42"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}" />

                            <TextBlock
                                Text="AI 协作调度台"
                                FontSize="23"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="这里记录 AI 如何参与团队管理：负责人提出问题，AI 给出建议，负责人进行人工判断，最终形成可追踪的管理动作。"
                                FontSize="15"
                                Foreground="{StaticResource MutedTextBrush}"
                                TextWrapping="Wrap"
                                MaxWidth="820" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Padding="12,6" CornerRadius="999" Background="#312E81">
                                    <TextBlock Text="自定义 API" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#4C1D95">
                                    <TextBlock Text="建议生成" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#064E3B">
                                    <TextBlock Text="人工判断" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>

                                <Border Padding="12,6" CornerRadius="999" Background="#7C2D12">
                                    <TextBlock Text="决策追踪" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="20"
                            CornerRadius="20"
                            Background="#241B2D47"
                            BorderBrush="#475569"
                            BorderThickness="1">

                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="AI 调度状态"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    x:Name="AiConfigStatusText"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap" />

                                <Border Padding="12" CornerRadius="14" Background="#241F3A">
                                    <TextBlock
                                        Text="AI 只提供建议，最终判断、取舍和管理动作仍由负责人完成。"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="记录总数" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="RecordCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                            <TextBlock Text="AI 协作过程" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="采纳记录" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="AcceptedCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" />
                            <TextBlock Text="直接进入方案" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="部分采纳" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="PartAcceptedCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                            <TextBlock Text="经人工修正" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="涉及模块" FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="ModuleCountText" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" />
                            <TextBlock Text="管理场景数量" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="22"
                    CornerRadius="24"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="协作洞察"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="用简洁指标判断 AI 是否真正进入团队管理流程，而不是停留在普通问答。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBlock
                                Grid.Column="1"
                                Text="Decision Trace"
                                FontSize="17"
                                Foreground="{StaticResource AccentPurpleBrush}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource InsightCardStyle}">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="最近协作模块" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="RecentModuleText" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource InsightCardStyle}">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="采纳结构" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="AdoptionSummaryText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource InsightCardStyle}">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="管理价值" FontSize="13" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="AiValueText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.25*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="提出问题"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="描述当前管理场景，生成结构化 AI 建议。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>

                            <TextBox
                                x:Name="RelatedModuleTextBox"
                                Header="关联模块"
                                PlaceholderText="例如：任务管理 / 周报复盘 / 人员调度 / 器材风险"
                                Style="{StaticResource EditorBoxStyle}" />

                            <ComboBox
                                x:Name="AdoptionStatusComboBox"
                                Header="采纳状态"
                                SelectedIndex="1">
                                <ComboBoxItem Content="采纳" />
                                <ComboBoxItem Content="部分采纳" />
                                <ComboBoxItem Content="未采纳" />
                                <ComboBoxItem Content="待判断" />
                            </ComboBox>

                            <TextBox
                                x:Name="QuestionTextBox"
                                Header="问题描述"
                                PlaceholderText="例如：当前任务较多，如何判断哪些任务需要优先处理？"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="170"
                                MaxHeight="260"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                Style="{StaticResource EditorBoxStyle}" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button
                                    x:Name="GenerateAiSuggestionButton"
                                    Content="生成 AI 建议"
                                    Click="GenerateAiSuggestionButton_Click" />

                                <Button
                                    Content="保存记录"
                                    Click="AddAiRecordButton_Click" />

                                <Button
                                    Content="清空"
                                    Click="ClearAiRecordFormButton_Click" />
                            </StackPanel>

                            <TextBlock
                                x:Name="AiRecordFormMessageText"
                                FontSize="14"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="24"
                        CornerRadius="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="建议、判断与决策"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="AI 生成的是建议，负责人需要在这里完成判断、修正与最终决策。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBox
                                x:Name="AiSuggestionTextBox"
                                Header="AI 建议"
                                PlaceholderText="点击左侧“生成 AI 建议”后，这里会自动填入内容。"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                MinHeight="220"
                                MaxHeight="360"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                Style="{StaticResource EditorBoxStyle}" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    x:Name="HumanJudgementTextBox"
                                    Grid.Column="0"
                                    Header="人工判断"
                                    PlaceholderText="记录你对 AI 建议的筛选、质疑、补充或修正。"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    MinHeight="150"
                                    MaxHeight="260"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    Style="{StaticResource EditorBoxStyle}" />

                                <TextBox
                                    x:Name="FinalDecisionTextBox"
                                    Grid.Column="1"
                                    Header="最终决策"
                                    PlaceholderText="记录最终采用的方案，以及为什么这样处理。"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    MinHeight="150"
                                    MaxHeight="260"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    Style="{StaticResource EditorBoxStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="24"
                    CornerRadius="24"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock
                                    Text="AI 协作记录"
                                    FontSize="25"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}" />

                                <TextBlock
                                    Text="列表只显示摘要，完整内容通过“查看详情”打开，避免长文本破坏页面布局。"
                                    FontSize="14"
                                    Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>

                            <Border Grid.Column="1" Padding="12,6" CornerRadius="999" Background="#241F3A" VerticalAlignment="Center">
                                <TextBlock Text="Traceable Records" FontSize="13" Foreground="{StaticResource AccentPurpleBrush}" />
                            </Border>
                        </Grid>

                        <ItemsControl
                            x:Name="AiRecordsListView">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,14"
                                        Padding="20"
                                        CornerRadius="20"
                                        Background="#1B2537"
                                        BorderBrush="#334155"
                                        BorderThickness="1">

                                        <StackPanel Spacing="14">

                                            <Grid ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock
                                                        Text="{Binding RelatedModule}"
                                                        FontSize="21"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource PrimaryTextBrush}"
                                                        TextWrapping="Wrap" />

                                                    <TextBlock
                                                        Text="{Binding Question}"
                                                        FontSize="14"
                                                        Foreground="{StaticResource SecondaryTextBrush}"
                                                        TextWrapping="Wrap"
                                                        MaxLines="2"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <Border
                                                    Grid.Column="1"
                                                    Padding="10,5"
                                                    CornerRadius="999"
                                                    Background="#2B2542"
                                                    VerticalAlignment="Top">
                                                    <TextBlock
                                                        Text="{Binding AdoptionStatus}"
                                                        FontSize="13"
                                                        Foreground="{StaticResource AccentPurpleBrush}" />
                                                </Border>

                                                <TextBlock
                                                    Grid.Column="2"
                                                    Text="{Binding CreatedAt}"
                                                    FontSize="13"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    VerticalAlignment="Top" />
                                            </Grid>

                                            <Grid ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.1*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Padding="14" CornerRadius="14" Background="#162033">
                                                    <StackPanel Spacing="6">
                                                        <TextBlock
                                                            Text="AI 建议"
                                                            FontSize="14"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource AccentPurpleBrush}" />

                                                        <TextBlock
                                                            Text="{Binding AiSuggestion}"
                                                            FontSize="14"
                                                            Foreground="{StaticResource SecondaryTextBrush}"
                                                            TextWrapping="Wrap"
                                                            MaxLines="5"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Padding="14" CornerRadius="14" Background="#162033">
                                                    <StackPanel Spacing="6">
                                                        <TextBlock
                                                            Text="人工判断"
                                                            FontSize="14"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource AccentOrangeBrush}" />

                                                        <TextBlock
                                                            Text="{Binding HumanJudgement}"
                                                            FontSize="14"
                                                            Foreground="{StaticResource SecondaryTextBrush}"
                                                            TextWrapping="Wrap"
                                                            MaxLines="5"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2" Padding="14" CornerRadius="14" Background="#162033">
                                                    <StackPanel Spacing="6">
                                                        <TextBlock
                                                            Text="最终决策"
                                                            FontSize="14"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource AccentGreenBrush}" />

                                                        <TextBlock
                                                            Text="{Binding FinalDecision}"
                                                            FontSize="14"
                                                            Foreground="{StaticResource SecondaryTextBrush}"
                                                            TextWrapping="Wrap"
                                                            MaxLines="5"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Button
                                                    Content="查看详情"
                                                    Tag="{Binding Id}"
                                                    Click="ShowAiRecordDetailButton_Click" />

                                                <Button
                                                    Content="标记采纳"
                                                    Tag="{Binding Id}"
                                                    Click="SetAcceptedButton_Click" />

                                                <Button
                                                    Content="标记部分采纳"
                                                    Tag="{Binding Id}"
                                                    Click="SetPartAcceptedButton_Click" />

                                                <Button
                                                    Content="标记未采纳"
                                                    Tag="{Binding Id}"
                                                    Click="SetRejectedButton_Click" />

                                                <Button
                                                    Content="删除记录"
                                                    Tag="{Binding Id}"
                                                    Click="DeleteAiRecordButton_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>