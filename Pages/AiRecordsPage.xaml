<Page
    x:Class="TeamFlowDesk.Pages.AiRecordsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock
                    Text="AI协作记录"
                    FontSize="32"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="用于记录 AI 在项目管理、任务拆解、风险分析、文档整理和周报生成过程中的辅助内容，并保留人工判断与修正结果。"
                    FontSize="16"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="20" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="记录总数" FontSize="14" />
                        <TextBlock x:Name="RecordCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="采纳记录" FontSize="14" />
                        <TextBlock x:Name="AcceptedCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="20" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="部分采纳" FontSize="14" />
                        <TextBlock x:Name="PartAcceptedCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="20" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="涉及模块" FontSize="14" />
                        <TextBlock x:Name="ModuleCountText" FontSize="30" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="16">

                    <TextBlock
                        Text="新增 AI 协作记录"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox
                            x:Name="RelatedModuleTextBox"
                            Grid.Row="0"
                            Grid.Column="0"
                            Header="关联模块"
                            PlaceholderText="例如：项目规划 / 技术路线 / 周报整理" />

                        <ComboBox
                            x:Name="AdoptionStatusComboBox"
                            Grid.Row="0"
                            Grid.Column="1"
                            Header="采纳状态"
                            SelectedIndex="1">
                            <ComboBoxItem Content="采纳" />
                            <ComboBoxItem Content="部分采纳" />
                            <ComboBoxItem Content="未采纳" />
                            <ComboBoxItem Content="待判断" />
                        </ComboBox>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="2"
                            Text="记录 AI 建议时，重点保留人工判断与修正过程。"
                            FontSize="14"
                            TextWrapping="Wrap"
                            VerticalAlignment="Bottom" />

                        <TextBox
                            x:Name="QuestionTextBox"
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Header="问题描述"
                            PlaceholderText="例如：两周开发周期内如何压缩系统功能范围？"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            MinHeight="70" />

                        <TextBox
                            x:Name="AiSuggestionTextBox"
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Header="AI 建议"
                            PlaceholderText="记录 AI 给出的原始建议或摘要"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            MinHeight="90" />

                        <TextBox
                            x:Name="HumanJudgementTextBox"
                            Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Header="人工判断"
                            PlaceholderText="记录你对 AI 建议的判断、筛选、质疑或补充"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            MinHeight="90" />

                        <TextBox
                            x:Name="FinalDecisionTextBox"
                            Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Header="最终决策"
                            PlaceholderText="记录最终采用的方案，以及为什么这样处理"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            MinHeight="90" />

                        <StackPanel
                            Grid.Row="4"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Bottom">

                            <Button
                                x:Name="GenerateAiSuggestionButton"
                                Content="生成 AI 建议"
                                Click="GenerateAiSuggestionButton_Click" />

                            <Button
                                Content="新增记录"
                                Click="AddAiRecordButton_Click" />

                            <Button
                                Content="清空输入"
                                Click="ClearAiRecordFormButton_Click" />
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        x:Name="AiRecordFormMessageText"
                        FontSize="14"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Spacing="12">
                <TextBlock
                    Text="AI 协作过程"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <ListView
                    x:Name="AiRecordsListView"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12"
                                Margin="0,0,0,8"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel Spacing="8">

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{Binding RelatedModule}"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding AdoptionStatus}"
                                            FontSize="14" />

                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{Binding CreatedAt}"
                                            FontSize="14" />
                                    </Grid>

                                    <TextBlock Text="问题描述" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Question}" FontSize="14" TextWrapping="Wrap" />

                                    <TextBlock Text="AI 建议" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AiSuggestion}" FontSize="14" TextWrapping="Wrap" />

                                    <TextBlock Text="人工判断" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding HumanJudgement}" FontSize="14" TextWrapping="Wrap" />

                                    <TextBlock Text="最终决策" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding FinalDecision}" FontSize="14" TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button
                                            Content="标记采纳"
                                            Tag="{Binding Id}"
                                            Click="SetAcceptedButton_Click" />

                                        <Button
                                            Content="标记部分采纳"
                                            Tag="{Binding Id}"
                                            Click="SetPartAcceptedButton_Click" />

                                        <Button
                                            Content="标记未采纳"
                                            Tag="{Binding Id}"
                                            Click="SetRejectedButton_Click" />

                                        <Button
                                            Content="删除记录"
                                            Tag="{Binding Id}"
                                            Click="DeleteAiRecordButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>