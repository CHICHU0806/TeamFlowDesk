<Window
    x:Class="TeamFlowDesk.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TeamFlowDesk">

    <Grid>
        <NavigationView
            x:Name="RootNavigationView"
            PaneTitle="TeamFlowDesk"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            Opacity="0"
            IsHitTestVisible="False"
            SelectionChanged="RootNavigationView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="管理驾驶舱" Tag="HomePage">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="项目管理" Tag="ProjectsPage">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Folder" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="任务管理" Tag="TasksPage">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="List" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="人员管理" Tag="MembersPage">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="People" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="器材管理" Tag="EquipmentPage">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Repair" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="AI协作记录" Tag="AiRecordsPage">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Comment" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="周报与复盘" Tag="ReportsPage">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Calendar" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="关于系统" Tag="AboutPage">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Help" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Grid
            x:Name="SplashOverlay"
            Background="#080D18"
            Opacity="1">

            <StackPanel
                x:Name="SplashContent"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">

                <StackPanel.RenderTransform>
                    <ScaleTransform x:Name="SplashScaleTransform" ScaleX="0.86" ScaleY="0.86" />
                </StackPanel.RenderTransform>

                <Border
                    Width="164"
                    Height="164"
                    Padding="22"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="18"
                    HorizontalAlignment="Center">

                    <Image
                        Source="ms-appx:///Assets/TeamFlowDeskIcon.png"
                        Stretch="Uniform" />
                </Border>

                <StackPanel HorizontalAlignment="Center" Spacing="5">
                    <TextBlock
                        Text="TeamFlowDesk"
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="#F8FAFC"
                        HorizontalAlignment="Center" />

                    <TextBlock
                        Text="团队运行管理工作流系统"
                        FontSize="14"
                        Foreground="#94A3B8"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
