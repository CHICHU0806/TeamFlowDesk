<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#4F46E5" />
        <Setter Property="Foreground" Value="#F8FAFC" />
        <Setter Property="BorderBrush" Value="#6366F1" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#1C2638" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#3F1D2A" />
        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
        <Setter Property="BorderBrush" Value="#7F1D1D" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="SuccessButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#064E3B" />
        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
        <Setter Property="BorderBrush" Value="#047857" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="WarningButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#7C2D12" />
        <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}" />
        <Setter Property="BorderBrush" Value="#C2410C" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

</ResourceDictionary>