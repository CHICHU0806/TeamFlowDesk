<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 基础背景 -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#080D18" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#162033" />
    <SolidColorBrush x:Key="CardHoverBackgroundBrush" Color="#1B2537" />
    <SolidColorBrush x:Key="SubCardBackgroundBrush" Color="#1B2638" />

    <!-- 边框 -->
    <SolidColorBrush x:Key="CardBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="SoftBorderBrush" Color="#2F3D55" />
    <SolidColorBrush x:Key="StrongBorderBrush" Color="#475569" />

    <!-- 文字 -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="WeakTextBrush" Color="#64748B" />

    <!-- 主题色 -->
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#60A5FA" />
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA" />
    <SolidColorBrush x:Key="AccentGreenBrush" Color="#34D399" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="#FB7185" />
    <SolidColorBrush x:Key="AccentCyanBrush" Color="#22D3EE" />

    <!-- 深色标签底色 -->
    <SolidColorBrush x:Key="BlueTagBackgroundBrush" Color="#172033" />
    <SolidColorBrush x:Key="PurpleTagBackgroundBrush" Color="#241F3A" />
    <SolidColorBrush x:Key="GreenTagBackgroundBrush" Color="#064E3B" />
    <SolidColorBrush x:Key="OrangeTagBackgroundBrush" Color="#7C2D12" />
    <SolidColorBrush x:Key="RedTagBackgroundBrush" Color="#3F1D2A" />

    <!-- 输入框 -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1C2638" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#40516B" />

    </ResourceDictionary>