<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="MetricCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="18" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="InsightCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="{StaticResource SubCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SoftBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PanelCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="24" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="LargePanelCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="28" />
        <Setter Property="CornerRadius" Value="26" />
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ListItemCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Background" Value="{StaticResource CardHoverBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SmallTagStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="{StaticResource BlueTagBackgroundBrush}" />
    </Style>

</ResourceDictionary>